{
  "name": "the-raki",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:clean": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true })\" && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "verify": "npm run lint && npm run build:clean",
    "geo:doctor": "node scripts/geo-doctor.mjs",
    "iiko:bindings-template": "node scripts/generate-iiko-bindings-template.mjs",
    "iiko:bindings-validate": "node scripts/validate-iiko-bindings.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.12.1",
    "lenis": "^1.3.21",
    "maplibre-gl": "^5.21.1",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
