{
  "name": "the-raki",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:clean": "node -e \"require('node:fs').rmSync('.next', { recursive: true, force: true })\" && next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "verify": "npm run lint && npm run build:clean",
    "geo:doctor": "node scripts/geo-doctor.mjs",
    "iiko:bindings-template": "node scripts/generate-iiko-bindings-template.mjs",
    "iiko:bindings-validate": "node scripts/validate-iiko-bindings.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.12.1",
    "lenis": "^1.3.21",
    "maplibre-gl": "^5.21.1",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.7",
    "@types/node": "^22.15.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.7",
    "typescript": "^5.8.3"
  }
}
