# iiko handoff
IIKO_API_BASE_URL=https://api-ru.iiko.services
IIKO_API_LOGIN=
IIKO_ORGANIZATION_ID=
IIKO_TERMINAL_GROUP_ID=
IIKO_SOURCE_KEY=theraki-site

# use one of the options below
IIKO_BINDINGS_FILE=./config/iiko-bindings.local.json
# IIKO_BINDINGS_JSON=

# geo / delivery quote
GEO_ENABLE_LIVE_SUGGEST=true
GEO_ENABLE_LIVE_QUOTE=true
GEO_ENABLE_LIVE_MAP=true
GEO_ENABLE_PAID_PROVIDER=true

GEO_SUGGEST_PROVIDER=dadata
GEO_ROUTING_PROVIDER=tomtom
GEO_ZONE_PROVIDER=static
# GEO_ZONE_FILE=./config/delivery-zones.local.json

DADATA_API_KEY=
TOMTOM_API_KEY=
TWOGIS_API_KEY=

# map style
# default local premium demo style lives at /public/map-styles/raki-investor-dark.json
NEXT_PUBLIC_MAP_STYLE_URL=/map-styles/raki-investor-dark.json

# public site origin for tracking links and callbacks
SITE_PUBLIC_URL=http://127.0.0.1:3043

# storage mode
ORDER_STORAGE_MODE=file
COURIER_STORAGE_MODE=file
